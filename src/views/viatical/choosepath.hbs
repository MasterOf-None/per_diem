<header>
    <h1>Seleccione la Ruta</h1>
</header>

<form action="/viatical/choosepath" method="POST">
  
  <fieldset>
    <legend>Origen</legend>
    
    <span><label>
      Seleccione la oficina de donde partirá

      <select name="choosePathOrigin" id="" required>
        <optgroup label="Seleccione">
          {{#each offices}}
            <option value="{{this}}">{{this}}</option>
          {{/each}}
        </optgroup>
      </select>

    </label></span>

  </fieldset>

  <fieldset>
    <legend>Destino</legend>
        <span><label>
          Seleccione el municipio de destino

          {{!-- <input name="choosePathDestiny" id="" placeholder="Escriba el municipio de destino" aria-label="Destino" required> --}}
          
          <select name="choosePathDestiny" id="">
            <optgroup label="Seleccione">
            {{#each offices}}
              <option value="{{this}}">{{this}}</option>
            {{/each}}
          </select>
        </label></span>

  </fieldset>
  
  <div>
    <input type="submit" name="choosePathBack" id="" value="Anterior">
    <input type="submit" name="choosePathSubmit" id="" value="Aceptar">
  </div>
</form>